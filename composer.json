{
  "name": "php-opcua/opcua-session-manager",
  "description": "Session manager daemon for persistent OPC UA connections in PHP — Unix socket IPC, automatic session recovery, subscription transfer",
  "homepage": "https://github.com/php-opcua/opcua-session-manager",
  "support": {
    "issues": "https://github.com/php-opcua/opcua-session-manager/issues",
    "source": "https://github.com/php-opcua/opcua-session-manager",
    "docs": "https://github.com/php-opcua/opcua-session-manager/tree/master/doc"
  },
  "type": "library",
  "license": "MIT",
  "authors": [
    {
      "name": "Gianfrancesco Aurecchia",
      "email": "gianfri.aur@gmail.com"
    }
  ],
  "keywords": [
    "opcua",
    "opc-ua",
    "opc ua",
    "session-manager",
    "daemon",
    "ipc",
    "persistent-connection",
    "industrial",
    "iot",
    "plc",
    "scada",
    "automation"
  ],
  "require": {
    "php": "^8.2",
    "php-opcua/opcua-client": "^4.3.0",
    "react/event-loop": "^1.5",
    "react/socket": "^1.16",
    "psr/log": "^3.0",
    "psr/simple-cache": "^3.0",
    "psr/event-dispatcher": "^1.0"
  },
  "autoload": {
    "psr-4": {
      "PhpOpcua\\SessionManager\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "PhpOpcua\\SessionManager\\Tests\\": "tests/"
    }
  },
  "bin": [
    "bin/opcua-session-manager"
  ],
  "require-dev": {
    "pestphp/pest": "^3.0"
  },
  "config": {
    "allow-plugins": {
      "pestphp/pest-plugin": true
    }
  }
}
