{
  "name": "gianfriaur/opcua-php-client-session-manager",
  "description": "Session manager daemon for persistent OPC UA connections in PHP",
  "type": "library",
  "license": "MIT",
  "require": {
    "php": "^8.2",
    "gianfriaur/opcua-php-client": "^3.0",
    "react/event-loop": "^1.5",
    "react/socket": "^1.16",
    "psr/log": "^3.0",
    "psr/simple-cache": "^3.0"
  },
  "autoload": {
    "psr-4": {
      "Gianfriaur\\OpcuaSessionManager\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Gianfriaur\\OpcuaSessionManager\\Tests\\": "tests/"
    }
  },
  "bin": [
    "bin/opcua-session-manager"
  ],
  "require-dev": {
    "pestphp/pest": "^3.0"
  },
  "config": {
    "allow-plugins": {
      "pestphp/pest-plugin": true
    }
  }
}
