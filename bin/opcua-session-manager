#!/usr/bin/env php
<?php

declare(strict_types=1);

$autoloadPaths = [
    __DIR__ . '/../vendor/autoload.php',
    __DIR__ . '/../../../autoload.php',
];

$autoloaderFound = false;
foreach ($autoloadPaths as $autoloadPath) {
    if (file_exists($autoloadPath)) {
        require $autoloadPath;
        $autoloaderFound = true;
        break;
    }
}

if (!$autoloaderFound) {
    fwrite(STDERR, "Could not find autoloader. Run 'composer install'.\n");
    exit(1);
}

use PhpOpcua\Client\Cache\FileCache;
use PhpOpcua\Client\Cache\InMemoryCache;
use PhpOpcua\SessionManager\Cli\ArgvParser;
use PhpOpcua\SessionManager\Daemon\SessionManagerDaemon;
use PhpOpcua\SessionManager\Logging\StreamLogger;

$defaults = require __DIR__ . '/../config/defaults.php';
$parsed = ArgvParser::parse($argv, $defaults);

if ($parsed['errors'] !== []) {
    foreach ($parsed['errors'] as $error) {
        fwrite(STDERR, $error . "\n");
    }
    fwrite(STDERR, "Run with --help for usage.\n");
    exit(1);
}

if ($parsed['action'] === 'version') {
    echo 'opcua-session-manager ' . SessionManagerDaemon::VERSION . "\n";
    exit(0);
}

if ($parsed['action'] === 'help') {
    echo "Usage: opcua-session-manager [options]\n";
    echo "\n";
    echo "Options:\n";
    echo "  --socket <uri>               IPC endpoint URI. Accepts unix://<path>, tcp://127.0.0.1:<port>, or a plain path (= unix://<path>). Default per OS: unix:///tmp/opcua-session-manager.sock on Linux/macOS, tcp://127.0.0.1:9990 on Windows.\n";
    echo "  --timeout <seconds>          Session timeout in seconds (default: 600)\n";
    echo "  --cleanup-interval <seconds>  Cleanup interval in seconds (default: 30)\n";
    echo "  --auth-token <token>         Shared secret for IPC authentication (prefer env var or file)\n";
    echo "  --auth-token-file <path>     Read auth token from file (recommended)\n";
    echo "  --max-sessions <n>           Maximum concurrent sessions (default: 100)\n";
    echo "  --socket-mode <octal>        Socket file permissions (default: 0600)\n";
    echo "  --allowed-cert-dirs <dirs>   Comma-separated list of allowed certificate directories\n";
    echo "  --log-file <path>            Log file path (default: stderr)\n";
    echo "  --log-level <level>          Minimum log level: debug, info, notice, warning, error (default: info)\n";
    echo "  --cache-driver <driver>      Cache driver: memory, file, none (default: memory)\n";
    echo "  --cache-path <path>          Cache directory for file driver (required when --cache-driver=file)\n";
    echo "  --cache-ttl <seconds>        Cache TTL in seconds (default: 300)\n";
    echo "  --help, -h                   Show this help message\n";
    echo "  --version, -v                Show the daemon version\n";
    echo "\n";
    echo "Environment variables:\n";
    echo "  OPCUA_AUTH_TOKEN             Auth token (highest priority, avoids /proc exposure)\n";
    exit(0);
}

$options = $parsed['options'];
$authTokenFromCli = $parsed['authTokenFromCli'];

$envToken = getenv('OPCUA_AUTH_TOKEN');
if (is_string($envToken) && $envToken !== '') {
    $options['auth_token'] = $envToken;
} elseif ($options['auth_token_file'] !== null) {
    if (!is_file($options['auth_token_file']) || !is_readable($options['auth_token_file'])) {
        fwrite(STDERR, "Auth token file not found or not readable: {$options['auth_token_file']}\n");
        exit(1);
    }
    $options['auth_token'] = trim(file_get_contents($options['auth_token_file']));
    if ($options['auth_token'] === '') {
        fwrite(STDERR, "Auth token file is empty: {$options['auth_token_file']}\n");
        exit(1);
    }
}

if ($authTokenFromCli && $options['auth_token'] !== null) {
    fwrite(STDERR, "WARNING: --auth-token is visible in the process list (ps/top).\n");
    fwrite(STDERR, "         Use OPCUA_AUTH_TOKEN env var or --auth-token-file instead.\n");
}

$logger = new StreamLogger($options['log_file'] ?? 'php://stderr', $options['log_level']);

$clientCache = match ($options['cache_driver']) {
    'file' => (function () use ($options) {
        if ($options['cache_path'] === null) {
            fwrite(STDERR, "--cache-path is required when --cache-driver=file\n");
            exit(1);
        }
        return new FileCache($options['cache_path'], $options['cache_ttl']);
    })(),
    'none' => null,
    default => new InMemoryCache($options['cache_ttl']),
};

$daemon = new SessionManagerDaemon(
    socketPath: $options['socket_path'],
    timeout: $options['timeout'],
    cleanupInterval: $options['cleanup_interval'],
    authToken: $options['auth_token'],
    maxSessions: $options['max_sessions'],
    socketMode: $options['socket_mode'],
    allowedCertDirs: $options['allowed_cert_dirs'],
    logger: $logger,
    clientCache: $clientCache,
);
$daemon->run();
